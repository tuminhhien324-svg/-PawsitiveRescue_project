      aria-labelledby="advocacyModalLabel"
      aria-hidden="true"
    >
      <div class="modal-dialog modal-dialog-centered">
        <div
          class="modal-content border border-3 border-dark rounded-md"
          style="background-color: var(--pawsitive-surface)"
        >
          <div class="modal-header border-0 pb-0">
            <h5
              class="modal-title brand-font fs-4 text-danger"
              id="advocacyModalLabel"
            >
              🐾 Tại sao nên nhận nuôi?
            </h5>
            <button
              type="button"
              class="btn-close"
              data-bs-dismiss="modal"
              aria-label="Close"
            ></button>
          </div>
          <div class="modal-body p-4 text-dark">
            <p class="fw-bold">1. Cứu sống một cuộc đời</p>
            <p class="small text-muted mb-3">
              Mỗi bé động vật nhận nuôi từ trạm sẽ trực tiếp giải phóng không
              gian để cứu trợ một động vật lang thang khác ngoài phố.
            </p>

            <p class="fw-bold">2. Nói KHÔNG với các trang trại nhân giống</p>
            <p class="small text-muted mb-3">
              Mua thú cưng từ các cơ sở thương mại thiếu đạo đức vô tình tiếp
              tay cho môi trường nuôi nhốt tồi tàn.
            </p>

            <p class="fw-bold">3. Chi phí hợp lý & Đã kiểm tra y tế</p>
            <p class="small text-muted m-0">
              Tất cả các bé tại Pawsitive Rescue đều được triệt sản, tiêm
              vắc-xin và kiểm tra y tế toàn diện miễn phí cho bạn.
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- Bootstrap 5 JS Bundle -->
    <!-- Interactive Filters Script -->
    <script>
      let activeSpecies = "all";
      let userFavorites = [];

      document.addEventListener("DOMContentLoaded", async () => {
        // Load favorites first if logged in
        await loadUserFavorites();

        // Initial pets load
        await loadPets();

        // Species tabs binding
        const buttons = {
          all: document.getElementById("filter-all"),
          dog: document.getElementById("filter-dog"),
          cat: document.getElementById("filter-cat"),
          other: document.getElementById("filter-other"),
        };

        function clearActive() {
          Object.values(buttons).forEach((btn) => {
            btn.classList.remove("btn-pawsitive-primary");
            btn.classList.add("btn-pawsitive-secondary");
          });
        }

        buttons.all.addEventListener("click", () => {
          clearActive();
          buttons.all.classList.add("btn-pawsitive-primary");
          activeSpecies = "all";
          loadPets();
        });

        buttons.dog.addEventListener("click", () => {
          clearActive();
          buttons.dog.classList.add("btn-pawsitive-primary");
          activeSpecies = "chó";
          loadPets();
        });

        buttons.cat.addEventListener("click", () => {
          clearActive();
          buttons.cat.classList.add("btn-pawsitive-primary");
          activeSpecies = "mèo";
          loadPets();
        });

        buttons.other.addEventListener("click", () => {
          clearActive();
          buttons.other.classList.add("btn-pawsitive-primary");
          activeSpecies = "khác";
          loadPets();
        });

        // Advanced filter bindings
        document.getElementById("select-age").addEventListener("change", loadPets);
        document.getElementById("select-gender").addEventListener("change", loadPets);
        document.getElementById("select-size").addEventListener("change", loadPets);
        
        let searchTimeout;
        document.getElementById("search-name").addEventListener("input", () => {
          clearTimeout(searchTimeout);
          searchTimeout = setTimeout(loadPets, 400);
        });
      });

      async function loadUserFavorites() {
        const user = pawsitiveCurrentUser();
        if (!user) return;

        try {
          const res = await fetch("/api/pets/favorites");
          const json = await res.json();
          if (json.success && json.data) {
            userFavorites = json.data.map(p => p.maThuCung);
          }
        } catch (err) {
          console.error("Failed to load user favorites:", err);
        }
      }

      function getFilterQuery() {
        const age = document.getElementById("select-age").value;
        const gender = document.getElementById("select-gender").value;
        const size = document.getElementById("select-size").value;
        const search = document.getElementById("search-name").value.trim();

        let query = "?";
        if (activeSpecies !== "all") {
          query += `loai=${encodeURIComponent(activeSpecies)}&`;
        }
        if (age) {
          query += `tuoi=${encodeURIComponent(age)}&`;
        }
        if (gender) {
          query += `gioitinh=${encodeURIComponent(gender)}&`;
        }
        if (size) {
          query += `kichthuoc=${encodeURIComponent(size)}&`;
        }
        if (search) {
          query += `q=${encodeURIComponent(search)}&`;
        }
        return query;
      }

      async function loadPets() {
        const grid = document.getElementById("pet-catalog-grid");
        grid.innerHTML = `
          <div class="col-12 text-center py-5">
            <div class="spinner-border text-danger" role="status">
              <span class="visually-hidden">Loading...</span>
            </div>
            <p class="mt-2 text-muted">Đang tải danh sách thú cưng...</p>
          </div>
        `;

        const query = getFilterQuery();
        try {
          const res = await fetch("/api/pets" + query);
          const json = await res.json();

          if (json.success && json.data) {
            const availablePets = json.data.filter(p => p.trangThaiNhanNuoi !== "Đã nhận nuôi");
            renderPets(availablePets);
          } else {
            showToast("❌ Không thể tải danh sách thú cưng: " + json.message, "error");
          }
        } catch (err) {
          console.error(err);
          showToast("❌ Lỗi kết nối đến máy chủ", "error");
        }
      }

      async function toggleLike(petId, btnElement) {
        const user = pawsitiveCurrentUser();
        if (!user) {
          showToast("⚠️ Vui lòng đăng nhập để lưu thú cưng yêu thích!", "error");
          setTimeout(() => {
            window.location.href = "/Account/Login?ReturnUrl=" + encodeURIComponent(window.location.pathname);
          }, 1500);
          return;
        }

        const icon = btnElement.querySelector("i");
        const isLiked = icon.classList.contains("bi-heart-fill");

        const method = isLiked ? "DELETE" : "POST";
        const toastMsg = isLiked ? "💔 Đang xóa khỏi mục yêu thích..." : "💖 Đang thêm vào mục yêu thích...";

        showToast(toastMsg, "info");

        try {
          const res = await fetch(`/api/pets/${petId}/favorite`, { method: method });
          const json = await res.json();

          if (json.success) {
            if (isLiked) {
              icon.className = "bi bi-heart";
              btnElement.className = "position-absolute top-0 end-0 m-2 bg-white text-muted rounded-full border border-2 border-dark d-flex align-items-center justify-content-center cursor-pointer liked-trigger";
              showToast("💔 Đã xóa khỏi danh sách yêu thích!", "success");
              userFavorites = userFavorites.filter(id => id !== petId);
            } else {
              icon.className = "bi bi-heart-fill";
              btnElement.className = "position-absolute top-0 end-0 m-2 bg-white text-danger rounded-full border border-2 border-dark d-flex align-items-center justify-content-center cursor-pointer liked-trigger";
              showToast("💖 Đã thêm vào danh sách yêu thích thành công!", "success");
              userFavorites.push(petId);
            }
          } else {
            showToast("❌ Thao tác thất bại: " + json.message, "error");
          }
        } catch (err) {
          console.error(err);
          showToast("❌ Lỗi kết nối đến máy chủ", "error");
        }
      }

      function renderPets(pets) {
        const grid = document.getElementById("pet-catalog-grid");
        grid.innerHTML = "";

        if (!pets || pets.length === 0) {
          grid.innerHTML = `
            <div class="col-12 text-center py-5">
              <span class="fs-1">🐾</span>
              <h3 class="brand-font mt-3">Không tìm thấy bạn nhỏ nào</h3>
              <p class="text-muted">Thử thay đổi bộ lọc hoặc tìm kiếm xem sao nhé!</p>
            </div>
          `;
          return;
        }

        pets.forEach(pet => {
          const isLiked = userFavorites.includes(pet.maThuCung);
          const heartClass = isLiked ? "bi-heart-fill" : "bi-heart";
          const heartColorClass = isLiked ? "text-danger" : "text-muted";
          
          const avatarUrl = pet.anhChinh || "https://images.unsplash.com/photo-1543466835-00a7907e9de1?auto=format&fit=crop&q=80&w=400";
          const ageDisplay = pet.giaTriTuoi ? `${pet.giaTriTuoi} ${pet.donViTuoi || 'Tuổi'}` : 'Chưa rõ';
          
          grid.innerHTML += `
            <div class="col-lg-4 col-md-6 pet-card-item">
              <div class="card-pawsitive h-100 d-flex flex-column justify-content-between">
                <div>
                  <div class="pet-frame ratio ratio-1x1 mb-3">
                    <img src="${avatarUrl}" alt="${pet.tenThuCung}" />
                    <div class="position-absolute top-0 end-0 m-2 bg-white ${heartColorClass} rounded-full border border-2 border-dark d-flex align-items-center justify-content-center cursor-pointer liked-trigger" style="width: 38px; height: 38px" onclick="event.preventDefault(); toggleLike(${pet.maThuCung}, this)">
                      <i class="bi ${heartClass}"></i>
                    </div>
                  </div>
                  <div class="d-flex justify-content-between align-items-center mb-2">
                    <h3 class="brand-font h4 m-0 text-danger">${pet.tenThuCung}</h3>
                    <span class="badge badge-pawsitive badge-pawsitive-primary">
                      <i class="bi ${pet.gioiTinh === 'Đực' ? 'bi-gender-male' : 'bi-gender-female'}"></i> ${ageDisplay}
                    </span>
                  </div>
                  <p class="small text-muted mb-3">${pet.moTa || 'Đang cập nhật mô tả...'}</p>
                </div>
                <div>
                  <div class="d-flex gap-2 mb-3">
                    <span class="badge badge-pawsitive badge-pawsitive-secondary">${pet.giongThuCung || 'Ngoại lai'}</span>
                    <span class="badge badge-pawsitive badge-pawsitive-secondary">${pet.trangThaiNhanNuoi || 'Chưa nhận nuôi'}</span>
                  </div>
                  <div class="d-flex gap-2">
                    <a class="btn btn-pawsitive btn-pawsitive-secondary rounded-full flex-grow-1 justify-content-center" href="/Home/Detail?id=${pet.maThuCung}">
                      Chi tiết
                    </a>
                    <a class="btn btn-pawsitive btn-pawsitive-primary rounded-full px-3" href="/Home/AdoptFlow?petId=${pet.maThuCung}">
                      <i class="bi bi-box-arrow-in-right"></i>
                    </a>
                  </div>
                </div>
              </div>
            </div>
          `;
        });
      }
    </script>
