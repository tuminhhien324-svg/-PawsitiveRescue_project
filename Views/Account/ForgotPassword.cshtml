@{
    ViewData["Title"] = "Khôi phục mật khẩu";
    Layout = "_Layout";
}

<div class="auth-fullscreen">
    
    <!-- LEFT SIDE: Brand presentation -->
    <div class="auth-brand-side text-center">
      <div style="max-width: 400px;">
        <a class="pawsitive-logo fs-1 justify-content-center mb-4" asp-controller="Home" asp-action="Index">
          🐾 Pawsitive Rescue
        </a>
        <p class="lead mb-4 text-dark font-bold">Khôi phục quyền truy cập tài khoản cứu hộ của bạn.</p>
        
        <div class="p-3 bg-white border border-2 border-dark rounded-md shadow-flat mb-4">
          <div class="pet-frame ratio ratio-1x1 border border-1 border-dark overflow-hidden">
            <img src="https://images.unsplash.com/photo-1514888286974-6c03e2ca1dba?auto=format&fit=crop&q=80&w=400" alt="Rescued cat portrait">
          </div>
        </div>
        <span class="small font-bold text-muted">Vì một thế giới đầy tình thương ấm áp 🏡</span>
      </div>
    </div>

    <!-- RIGHT SIDE: Recover Steps Form -->
    <div class="auth-form-side">
      <div style="max-width: 450px; margin: 0 auto; width: 100%;">
        
        <!-- STEP 1: Enter Email -->
        <div class="recover-step" id="recover-step-1">
          <h2 class="brand-font h1 text-danger mb-2">Quên mật khẩu?</h2>
          <p class="text-muted small mb-4">Nhập email đã đăng ký để nhận mã xác minh khôi phục mật khẩu của bạn.</p>

          <form>
            <div class="form-group-pawsitive mb-4">
              <label for="recover-email">Địa chỉ Email đăng ký</label>
              <div class="input-group">
                <span class="input-group-text bg-white border-2 border-end-0 border-dark" style="border-radius: 1rem 0 0 1rem;"><i class="bi bi-envelope"></i></span>
                <input type="email" class="form-control form-control-pawsitive border-start-0" id="recover-email" placeholder="example@gmail.com" required style="border-radius: 0 1rem 1rem 0;">
              </div>
            </div>

            <button type="button" class="btn btn-pawsitive btn-pawsitive-primary w-100 rounded-full justify-content-center py-2 fs-5 mb-4" id="btn-recover-1">
              Gửi mã xác nhận ➔
            </button>

            <div class="text-center small">
              Quay lại đăng nhập? <a asp-controller="Account" asp-action="Login" class="text-danger fw-bold text-decoration-none">Đăng nhập tại đây</a>
            </div>
          </form>
        </div>

        <!-- STEP 2: Enter OTP Code -->
        <div class="recover-step d-none" id="recover-step-2">
          <h2 class="brand-font h2 text-danger mb-2">Nhập mã xác minh</h2>
          <p class="text-muted small mb-4">Chúng tôi đã gửi mã xác minh 6 số tới email của bạn. Vui lòng kiểm tra hộp thư.</p>

          <form>
            <div class="form-group-pawsitive mb-3">
              <label for="recover-code">Mã xác minh (OTP)</label>
              <input type="text" class="form-control form-control-pawsitive text-center fs-3 tracking-widest" id="recover-code" placeholder="123456" maxlength="6" required>
            </div>

            <div class="text-center small text-muted font-bold mb-4" id="mock-countdown">
              Gửi lại mã sau 59s
            </div>

            <button type="button" class="btn btn-pawsitive btn-pawsitive-primary w-100 rounded-full justify-content-center py-2 fs-5 mb-4" id="btn-recover-2">
              Xác minh mã ➔
            </button>
          </form>
        </div>

        <!-- STEP 3: Change Password -->
        <div class="recover-step d-none" id="recover-step-3">
          <h2 class="brand-font h2 text-danger mb-2">Đặt lại mật khẩu</h2>
          <p class="text-muted small mb-4">Thiết lập mật khẩu mới cực kỳ bảo mật để hoàn thành hành trình khôi phục.</p>

          <form>
            <div class="form-group-pawsitive mb-3">
              <label for="recover-pass-1">Mật khẩu mới</label>
              <input type="password" class="form-control form-control-pawsitive" id="recover-pass-1" placeholder="Tối thiểu 6 ký tự" required>
            </div>
            
            <div class="form-group-pawsitive mb-4">
              <label for="recover-pass-2">Xác nhận mật khẩu mới</label>
              <input type="password" class="form-control form-control-pawsitive" id="recover-pass-2" placeholder="Nhập lại mật khẩu mới" required>
            </div>

            <button type="button" class="btn btn-pawsitive btn-pawsitive-primary w-100 rounded-full justify-content-center py-2 fs-5 mb-4" id="btn-recover-3">
              Đặt lại mật khẩu ✓
            </button>
          </form>
        </div>

      </div>
    </div>

  </div>

  <!-- Bootstrap 5 JS Bundle -->
  <!-- Password Recovery Logic -->
  <script src="~/js/recover.js"></script>
