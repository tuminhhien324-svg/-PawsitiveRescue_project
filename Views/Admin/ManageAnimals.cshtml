@{
    ViewData["Title"] = "Quản lý thú cưng";
    Layout = "_AdminLayout";
}

<div class="db-layout">
      <!-- ═══ Sidebar ═══ -->
      <aside class="db-sidebar" id="dbSidebar">
        <a asp-controller="Admin" asp-action="Index" class="db-sidebar-logo">
          <div class="db-sidebar-logo-icon">🐾</div>
          <div>
            <div class="db-sidebar-logo-text">Pawsitive Rescue</div>
            <span class="db-sidebar-logo-sub">Hệ thống Quản trị</span>
          </div>
        </a>
        <nav class="db-sidebar-nav">
          <a asp-controller="Admin" asp-action="Index" class="db-sidebar-link"
            ><i class="bi bi-grid-1x2-fill"></i> Tổng quan</a>
          <a asp-controller="Admin" asp-action="ManageAnimals" class="db-sidebar-link active"
            ><i class="bi bi-heart-pulse-fill"></i> Quản lý Động vật</a>
          <a asp-controller="Admin" asp-action="ManageAdopters" class="db-sidebar-link"
            ><i class="bi bi-house-heart-fill"></i> Nhận nuôi</a>
          <a asp-controller="Admin" asp-action="ManageVolunteers" class="db-sidebar-link"
            ><i class="bi bi-people-fill"></i> Tình nguyện viên</a>
          <a asp-controller="Admin" asp-action="ManageDonations" class="db-sidebar-link"
            ><i class="bi bi-gift-fill"></i> Quyên góp</a>
          <a asp-controller="Admin" asp-action="ManageRescues" class="db-sidebar-link">
            <i class="bi bi-exclamation-triangle-fill"></i> Cứu hộ Khẩn cấp
          </a>
        </nav>
        <div class="db-sidebar-bottom">
          <a href="#" class="db-sidebar-link" onclick="pawsitiveLogout(); return false;"><i class="bi bi-box-arrow-left"></i> Đăng xuất</a>
        </div>
      </aside>

      <div class="db-overlay" id="dbOverlay"></div>

      <!-- ═══ Main Content ═══ -->
      <main class="db-main">
        <!-- Top Bar -->
        <header class="db-topbar">
          <button class="db-mobile-toggle" id="dbMobileToggle">
            <i class="bi bi-list"></i>
          </button>
          <nav class="d-none d-md-flex gap-3 me-auto">
            <a asp-controller="Home" asp-action="Index" class="pawsitive-nav-link">Trang chủ</a>
            <a asp-controller="Admin" asp-action="ManageAnimals" class="pawsitive-nav-link active">Động vật</a>
          </nav>
          <div class="db-topbar-icon"><i class="bi bi-bell-fill"></i></div>
          <div class="db-topbar-icon"><i class="bi bi-gear-fill"></i></div>
          <div class="db-topbar-avatar">
            <img
              src="https://cdn-icons-png.flaticon.com/512/149/149071.png"
              alt="Avatar"
            />
          </div>
        </header>

        <div class="db-content">
          <!-- Page Header -->
          <div class="db-page-header db-animate-in">
            <div>
              <h1 class="db-page-title">Quản lý Động vật</h1>
              <p class="db-page-subtitle">
                Xem, thêm, sửa và xóa thông tin các bé thú cưng tại trạm Pawsitive.
              </p>
            </div>
            <div class="db-page-actions">
              <button class="db-btn db-btn-primary" data-bs-toggle="modal" data-bs-target="#addPetModal">
                <i class="bi bi-plus-lg"></i> Thêm thú cưng
              </button>
            </div>
          </div>

          <!-- Stats Summary Card -->
          <div class="row g-3 mb-4 db-animate-in">
            <div class="col-md-3">
              <div class="db-stat-card">
                <div class="db-stat-icon primary"><i class="bi bi-heart-fill"></i></div>
                <div class="db-stat-info">
                  <div class="db-stat-label">Tổng số bé</div>
                  <div class="db-stat-value" id="statTotalPets">0</div>
                </div>
              </div>
            </div>
            <div class="col-md-3">
              <div class="db-stat-card">
                <div class="db-stat-icon secondary">🐕</div>
                <div class="db-stat-info">
                  <div class="db-stat-label">Số lượng Chó</div>
                  <div class="db-stat-value" id="statDogs">0</div>
                </div>
              </div>
            </div>
            <div class="col-md-3">
              <div class="db-stat-card">
                <div class="db-stat-icon tertiary">🐈</div>
                <div class="db-stat-info">
                  <div class="db-stat-label">Số lượng Mèo</div>
                  <div class="db-stat-value" id="statCats">0</div>
                </div>
              </div>
            </div>
            <div class="col-md-3">
              <div class="db-stat-card">
                <div class="db-stat-icon accent"><i class="bi bi-check-circle-fill"></i></div>
                <div class="db-stat-info">
                  <div class="db-stat-label">Đã nhận nuôi</div>
                  <div class="db-stat-value" id="statAdopted">0</div>
                </div>
              </div>
            </div>
          </div>

          <!-- Main Table Card -->
          <div class="db-card db-animate-in">
            <!-- Filter Row -->
            <div class="row g-3 mb-4 align-items-center">
              <div class="col-md-4">
                <div class="db-topbar-search w-100 m-0">
                  <i class="bi bi-search"></i>
                  <input type="text" id="filterSearch" placeholder="Tìm tên, giống hoặc mô tả..." />
                </div>
              </div>
              <div class="col-md-3">
                <select class="form-select form-control-pawsitive" id="filterSpecies">
                  <option value="">Tất cả loài (Chó & Mèo)</option>
                  <option value="chó">Chó</option>
                  <option value="mèo">Mèo</option>
                  <option value="khác">Khác</option>
                </select>
              </div>
              <div class="col-md-3">
                <select class="form-select form-control-pawsitive" id="filterAdoptionStatus">
                  <option value="">Tất cả trạng thái nhận nuôi</option>
                  <option value="Chưa nhận nuôi">Chưa nhận nuôi</option>
                  <option value="Đang xử lý">Đang xử lý</option>
                  <option value="Đã nhận nuôi">Đã nhận nuôi</option>
                </select>
              </div>
              <div class="col-md-2">
                <button class="db-btn db-btn-secondary w-100 animate-hover" onclick="loadPets()">
                  <i class="bi bi-funnel-fill"></i> Lọc
                </button>
              </div>
            </div>

            <!-- Table -->
            <div class="table-responsive">
              <table class="db-table">
                <thead>
                  <tr>
                    <th>Ảnh</th>
                    <th>Tên</th>
                    <th>Loài / Giống</th>
                    <th>Tuổi / Giới tính</th>
                    <th>Sức khỏe</th>
                    <th>Cứu hộ</th>
                    <th>Nhận nuôi</th>
                    <th style="width: 120px;">Hành động</th>
                  </tr>
                </thead>
                <tbody id="petTableBody">
                  <tr>
                    <td colspan="8" class="text-center py-4 text-muted">Đang tải danh sách thú cưng...</td>
                  </tr>
                </tbody>
              </table>
            </div>
          </div>
        </div>

        <footer class="db-footer">
          <span class="db-footer-text"
            >© 2026 Pawsitive Rescue. Hệ thống Quản trị</span
          >
          <div class="db-footer-links">
            <a href="#">Trung tâm trợ giúp</a>
            <a href="#">Báo cáo lỗi</a>
          </div>
        </footer>
      </main>
</div>

<!-- ═══ MODALS ═══ -->

<!-- Add Pet Modal -->
<div class="modal fade" id="addPetModal" tabindex="-1" aria-labelledby="addPetModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-centered">
    <div class="modal-content custom-modal-content border-2 border-dark" style="border-radius: 20px; box-shadow: 6px 6px 0px #000;">
      <div class="modal-header border-bottom border-2 border-dark" style="background-color: var(--pawsitive-surface-container);">
        <h5 class="modal-title font-bold" id="addPetModalLabel">🐾 Thêm thú cưng mới</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <form id="addPetForm">
        <div class="modal-body">
          <div class="row g-3">
            <div class="col-12 pb-3 border-bottom border-2 border-secondary border-opacity-10">
              <label class="form-label font-bold text-primary"><i class="bi bi-download"></i> Nhập dữ liệu tự động từ ca cứu hộ đã hoàn thành</label>
              <select class="form-select border-2 border-primary" id="importRescueSelect">
                <option value="">-- Chọn ca cứu hộ đã hoàn thành --</option>
              </select>
            </div>
            <div class="col-md-6">
              <label class="form-label font-semibold">Tên thú cưng <span class="text-danger">*</span></label>
              <input type="text" class="form-control" name="TenThuCung" required placeholder="Nhập tên bé..." />
            </div>
            <div class="col-md-6">
              <label class="form-label font-semibold">Loài <span class="text-danger">*</span></label>
              <select class="form-select" name="LoaiNguonGoc" id="addPetSpeciesSelect" required>
                <option value="Chó">Chó</option>
                <option value="Mèo">Mèo</option>
                <option value="Khác">Khác</option>
              </select>
              <div class="mt-2 d-none" id="addPetOtherSpeciesContainer">
                <input type="text" class="form-control" id="addPetOtherSpeciesInput" placeholder="Nhập loài động vật khác (vd: Thỏ, Rùa...)" />
              </div>
            </div>
            <div class="col-md-6">
              <label class="form-label font-semibold">Giống thú cưng</label>
              <input type="text" class="form-control" name="GiongThuCung" placeholder="Ví dụ: Poodle, Mèo Anh lông ngắn..." />
            </div>
            <div class="col-md-3">
              <label class="form-label font-semibold">Tuổi</label>
              <input type="number" step="0.1" class="form-control" name="GiaTriTuoi" placeholder="Ví dụ: 1.5, 2..." />
            </div>
            <div class="col-md-3">
              <label class="form-label font-semibold">Đơn vị tuổi</label>
              <select class="form-select" name="DonViTuoi">
                <option value="Tuổi">Tuổi</option>
                <option value="Tháng">Tháng</option>
              </select>
            </div>
            <div class="col-md-6">
              <label class="form-label font-semibold">Giới tính</label>
              <select class="form-select" name="GioiTinh">
                <option value="Đực">Đực</option>
                <option value="Cái">Cái</option>
              </select>
            </div>
            <div class="col-md-6">
              <label class="form-label font-semibold">Ảnh chính <span class="text-danger">*</span></label>
              <input type="file" class="form-control" id="addPetImageFile" accept="image/*" />
              <input type="hidden" name="AnhChinh" id="addPetImageUrl" required />
              <div class="mt-2 border border-2 border-dark rounded-md overflow-hidden d-none" id="addPetImagePreviewContainer" style="width: 100px; height: 100px;">
                <img id="addPetImagePreview" class="w-100 h-100" style="object-fit: cover;" />
              </div>
            </div>
            <div class="col-md-6">
              <label class="form-label font-semibold">Tình trạng sức khỏe</label>
              <input type="text" class="form-control" name="TinhTrangSucKhoe" placeholder="Ví dụ: Khỏe mạnh, Đang hồi phục..." />
            </div>
            <div class="col-md-6">
              <label class="form-label font-semibold">Ngày cứu hộ</label>
              <input type="date" class="form-control" name="NgayCuuHo" />
            </div>
            <div class="col-md-6">
              <label class="form-label font-semibold">Trạng thái cứu hộ <span class="text-danger">*</span></label>
              <select class="form-select" name="TrangThaiCuuHo" required>
                <option value="ĐANG CHỜ">ĐANG CHỜ</option>
                <option value="ĐÃ NHẬN">ĐÃ NHẬN</option>
                <option value="ĐANG CỨU HỘ">ĐANG CỨU HỘ</option>
                <option value="ĐÃ HOÀN THÀNH">ĐÃ HOÀN THÀNH</option>
              </select>
            </div>
            <div class="col-md-6">
              <label class="form-label font-semibold">Trạng thái nhận nuôi <span class="text-danger">*</span></label>
              <select class="form-select" name="TrangThaiNhanNuoi" required>
                <option value="Chưa nhận nuôi">Chưa nhận nuôi</option>
                <option value="Đang xử lý">Đang xử lý</option>
                <option value="Đã nhận nuôi">Đã nhận nuôi</option>
              </select>
            </div>
            <div class="col-12">
              <label class="form-label font-semibold">Mô tả chi tiết</label>
              <textarea class="form-control" name="MoTa" rows="3" placeholder="Mô tả về tính cách, hoàn cảnh cứu hộ..."></textarea>
            </div>
            <div class="col-md-6">
              <label class="form-label font-semibold">Đặc điểm (cách nhau bởi dấu phẩy)</label>
              <input type="text" class="form-control" name="DacDiem" placeholder="Ví dụ: Thân thiện trẻ nhỏ, Thích ở trong nhà..." />
            </div>
            <div class="col-md-6">
              <label class="form-label font-semibold">Tiêm ngừa hay chưa</label>
              <input type="text" class="form-control" name="TiemNgua" placeholder="Ví dụ: Đã tiêm ngừa, Chưa tiêm..." />
            </div>
            <div class="col-12">
              <label class="form-label font-semibold">Sở thích (cách nhau bởi dấu phẩy)</label>
              <input type="text" class="form-control" name="SoThich" placeholder="Ví dụ: Thích ăn hạt, Thích đi dạo..." />
            </div>
          </div>
        </div>
        <div class="modal-footer border-top border-2 border-dark" style="background-color: var(--pawsitive-surface-container);">
          <button type="button" class="btn btn-secondary rounded-xl py-2 px-3 border border-dark" data-bs-dismiss="modal">Đóng</button>
          <button type="submit" class="btn btn-pawsitive btn-pawsitive-primary text-white rounded-xl py-2 px-4">Lưu thú cưng</button>
        </div>
      </form>
    </div>
  </div>
</div>

