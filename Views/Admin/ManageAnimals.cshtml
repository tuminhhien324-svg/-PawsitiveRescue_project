    </div>
  </div>
</div>

<!-- Delete Confirm Modal -->
<div class="modal fade" id="deletePetModal" tabindex="-1" aria-labelledby="deletePetModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered" style="max-width: 400px;">
    <div class="modal-content custom-modal-content border-2 border-dark" style="border-radius: 20px; box-shadow: 6px 6px 0px #000;">
      <div class="modal-header border-bottom border-2 border-dark bg-danger bg-opacity-10 text-danger">
        <h5 class="modal-title font-bold" id="deletePetModalLabel">⚠️ Xác nhận xóa</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body py-4 text-center">
        <i class="bi bi-exclamation-triangle-fill text-danger" style="font-size: 3rem;"></i>
        <h5 class="font-bold mt-3">Xóa bé <span id="deletePetName" class="text-danger"></span>?</h5>
        <p class="text-muted small mt-2 mb-0">Hành động này không thể hoàn tác. Mọi hồ sơ sức khỏe và dữ liệu liên quan sẽ bị xóa vĩnh viễn.</p>
      </div>
      <div class="modal-footer border-top border-2 border-dark" style="background-color: var(--pawsitive-surface-container);">
        <button type="button" class="btn btn-secondary rounded-xl py-2 px-3 border border-dark" data-bs-dismiss="modal">Hủy</button>
        <button type="button" id="confirmDeleteBtn" class="btn btn-danger text-white rounded-xl py-2 px-4">Đồng ý xóa</button>
      </div>
    </div>
  </div>
</div>

<!-- Manage Rescue Costs Modal -->
<div class="modal fade" id="manageRescueCostsModal" tabindex="-1" aria-labelledby="manageRescueCostsModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-centered">
    <div class="modal-content custom-modal-content border-2 border-dark" style="border-radius: 20px; box-shadow: 6px 6px 0px #000;">
      <div class="modal-header border-bottom border-2 border-dark" style="background-color: var(--pawsitive-surface-container);">
        <h5 class="modal-title font-bold" id="manageRescueCostsModalLabel">🐾 Quản lý Chi phí Cứu hộ: <span id="costsPetName" class="text-danger"></span></h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <div class="row g-4">
          <!-- Left side: Costs list -->
          <div class="col-lg-7 border-end border-2 border-secondary border-opacity-10">
            <h6 class="font-bold mb-3"><i class="bi bi-card-list"></i> Danh sách chi phí phát sinh</h6>
            <div class="table-responsive" style="max-height: 300px; overflow-y: auto;">
              <table class="table table-sm table-hover align-middle">
                <thead>
                  <tr>
                    <th>Loại</th>
                    <th>Số tiền</th>
                    <th>Ngày chi</th>
                    <th style="width: 50px;"></th>
                  </tr>
                </thead>
                <tbody id="rescueCostsTableBody">
                  <tr>
                    <td colspan="4" class="text-center text-muted">Không có chi phí nào.</td>
                  </tr>
                </tbody>
              </table>
            </div>
            <div class="d-flex justify-content-between align-items-center mt-3 pt-3 border-top border-2 border-secondary border-opacity-10">
              <span class="font-bold">Tổng chi phí cứu hộ:</span>
              <span class="font-bold text-danger fs-5" id="costsTotalSum">0 đ</span>
            </div>
          </div>
          <!-- Right side: Add cost form -->
          <div class="col-lg-5">
            <h6 class="font-bold mb-3"><i class="bi bi-plus-circle"></i> Thêm khoản chi mới</h6>
            <form id="addRescueCostForm">
              <div class="mb-3">
                <label class="form-label font-semibold">Loại chi phí <span class="text-danger">*</span></label>
                <select class="form-select" name="LoaiChiPhi" required>
                  <option value="Viện phí">Viện phí</option>
                  <option value="Thức ăn">Thức ăn</option>
                  <option value="Phụ kiện">Phụ kiện</option>
                  <option value="Vận chuyển">Vận chuyển</option>
                </select>
              </div>
              <div class="mb-3">
                <label class="form-label font-semibold">Số tiền (VND) <span class="text-danger">*</span></label>
                <input type="number" class="form-control" name="SoTien" required min="1000" placeholder="Ví dụ: 150000" />
              </div>
              <div class="mb-3">
                <label class="form-label font-semibold">Ngày chi thực tế</label>
                <input type="date" class="form-control" name="NgayChiTieu" required />
              </div>
              <div class="mb-3">
                <label class="form-label font-semibold">Ghi chú / Mô tả <span class="text-danger">*</span></label>
                <textarea class="form-control" name="MucDichChiTiet" rows="2" required placeholder="Chi tiết thuốc men, xét nghiệm..."></textarea>
              </div>
              <button type="submit" class="btn btn-pawsitive btn-pawsitive-primary text-white w-100 rounded-xl py-2 mt-2">
                <i class="bi bi-check-lg"></i> Thêm khoản chi
              </button>
            </form>
          </div>
        </div>
      </div>
      <div class="modal-footer border-top border-2 border-dark" style="background-color: var(--pawsitive-surface-container);">
        <button type="button" class="btn btn-secondary rounded-xl py-2 px-4 border border-dark" data-bs-dismiss="modal">Đóng</button>
      </div>
    </div>
  </div>
</div>

<div class="db-toast" id="dbToast"></div>

@section Scripts {
  <script>
    let currentPets = [];
    let deleteTargetId = null;
    let currentPetCostsId = null;

    // Bootstrap Modal instances
    const addPetModal = new bootstrap.Modal(document.getElementById('addPetModal'));
    const editPetModal = new bootstrap.Modal(document.getElementById('editPetModal'));
    const deletePetModal = new bootstrap.Modal(document.getElementById('deletePetModal'));
    const manageRescueCostsModal = new bootstrap.Modal(document.getElementById('manageRescueCostsModal'));

    document.addEventListener('DOMContentLoaded', () => {
        loadPets();
        loadCompletedRescues();

        // Register form submissions
        document.getElementById('addRescueCostForm').addEventListener('submit', handleAddRescueCost);

        // Toggle Custom Animal Species input
        const addSelect = document.getElementById('addPetSpeciesSelect');
        const addOtherContainer = document.getElementById('addPetOtherSpeciesContainer');
        const addOtherInput = document.getElementById('addPetOtherSpeciesInput');
        if (addSelect && addOtherContainer) {
            addSelect.addEventListener('change', () => {
                if (addSelect.value === 'Khác') {
                    addOtherContainer.classList.remove('d-none');
                    addOtherInput.setAttribute('required', 'required');
                } else {
                    addOtherContainer.classList.add('d-none');
                    addOtherInput.removeAttribute('required');
                }
            });
        }

        const editSelect = document.getElementById('editPetSpeciesSelect');
        const editOtherContainer = document.getElementById('editPetOtherSpeciesContainer');
        const editOtherInput = document.getElementById('editPetOtherSpeciesInput');
        if (editSelect && editOtherContainer) {
            editSelect.addEventListener('change', () => {
                if (editSelect.value === 'Khác') {
                    editOtherContainer.classList.remove('d-none');
                    editOtherInput.setAttribute('required', 'required');
                } else {
                    editOtherContainer.classList.add('d-none');
                    editOtherInput.removeAttribute('required');
                }
            });
        }

        // Register form submissions
        document.getElementById('addPetForm').addEventListener('submit', handleAddPet);
        document.getElementById('editPetForm').addEventListener('submit', handleEditPet);
        document.getElementById('confirmDeleteBtn').addEventListener('click', handleDeletePet);

        // Upload image event listeners
        document.getElementById('addPetImageFile').addEventListener('change', async (e) => {
            const file = e.target.files[0];
            if (!file) return;
            const formData = new FormData();
            formData.append('file', file);
            try {
                dbToast('📤 Đang tải ảnh lên...');
                const res = await fetch('/api/pets/upload-image', {
                    method: 'POST',
                    body: formData
                });
                const json = await res.json();
                if (json.success) {
                    document.getElementById('addPetImageUrl').value = json.data.path;
                    const preview = document.getElementById('addPetImagePreview');
                    preview.src = json.data.path;
                    document.getElementById('addPetImagePreviewContainer').classList.remove('d-none');
                    dbToast('✔️ Tải ảnh lên thành công!');
                } else {
                    alert('Tải ảnh thất bại: ' + json.message);
                }
            } catch (err) {
                console.error(err);
                alert('Lỗi khi tải ảnh lên.');
            }
        });

        document.getElementById('editPetImageFile').addEventListener('change', async (e) => {
            const file = e.target.files[0];
            if (!file) return;
            const formData = new FormData();
            formData.append('file', file);
            try {
                dbToast('📤 Đang tải ảnh lên...');
                const res = await fetch('/api/pets/upload-image', {
                    method: 'POST',
                    body: formData
                });
                const json = await res.json();
                if (json.success) {
                    document.getElementById('editPetImageUrl').value = json.data.path;
                    const preview = document.getElementById('editPetImagePreview');
                    preview.src = json.data.path;
                    dbToast('✔️ Tải ảnh lên thành công!');
                } else {
                    alert('Tải ảnh thất bại: ' + json.message);
                }
            } catch (err) {
                console.error(err);
                alert('Lỗi khi tải ảnh lên.');
            }
        });

        // Optional search input behavior (trigger search on enter)
        document.getElementById('filterSearch').addEventListener('keypress', (e) => {
            if (e.key === 'Enter') {
                loadPets();
            }
        });

        // Listen for completed rescue reports import selection
        document.getElementById('importRescueSelect').addEventListener('change', (e) => {
            const option = e.target.selectedOptions[0];
            if (!option || !option.value) return;

            const desc = option.getAttribute('data-desc') || '';
            const loc = option.getAttribute('data-loc') || '';
            const date = option.getAttribute('data-date') || '';

            const form = document.getElementById('addPetForm');
            form.querySelector('input[name="TenThuCung"]').value = `Bé SOS-${option.value}`;
            form.querySelector('textarea[name="MoTa"]').value = `Địa điểm cứu hộ: ${loc}.\nChi tiết: ${desc}`;
            if (date) {
                form.querySelector('input[name="NgayCuuHo"]').value = date.substring(0, 10);
            }

            // Simple auto-casing logic
            const lowercaseDesc = desc.toLowerCase();
            const speciesSelect = form.querySelector('select[name="LoaiNguonGoc"]');
            if (lowercaseDesc.includes('chó') || lowercaseDesc.includes('dog') || lowercaseDesc.includes('cún')) {
                speciesSelect.value = "Chó";
            } else if (lowercaseDesc.includes('mèo') || lowercaseDesc.includes('cat') || lowercaseDesc.includes('kitten')) {
                speciesSelect.value = "Mèo";
            } else {
                speciesSelect.value = "Khác";
            }
            if (speciesSelect) {
                speciesSelect.dispatchEvent(new Event('change'));
            }

            dbToast('📥 Nhập dữ liệu cứu hộ thành công!');
        });
    });

    async function loadCompletedRescues() {
        try {
            const res = await fetch('/api/Rescue/admin/rescue-reports?trangthai=Đã hoàn thành');
            const json = await res.json();
            if (json.success) {
                const select = document.getElementById('importRescueSelect');
                select.innerHTML = '<option value="">-- Chọn ca cứu hộ đã hoàn thành --</option>';
                json.data.forEach(r => {
                    const option = document.createElement('option');
                    option.value = r.maBaoCao;
                    option.setAttribute('data-desc', r.moTaChiTiet);
                    option.setAttribute('data-loc', r.diaDiem);
                    option.setAttribute('data-date', r.ngayBaoCao);
                    option.textContent = `Ca SOS-${r.maBaoCao} - ${r.diaDiem.substring(0, 30)} (${r.tenNguoiBaoCao || 'Khách'})`;
                    select.appendChild(option);
                });
            }
        } catch (err) {
            console.error('Error loading completed rescues:', err);
        }
    }

    // Helper: Form data to JSON object
    function getFormData(formElement) {
        const formData = new FormData(formElement);
        const obj = {};
        formData.forEach((value, key) => {
            if (key === 'GiaTriTuoi') {
                obj[key] = value ? parseFloat(value) : null;
            } else if (key === 'NgayCuuHo') {
                obj[key] = value ? value : null;
            } else {
                obj[key] = value;
            }
        });

        // Use custom species if select value is "Khác"
        if (obj['LoaiNguonGoc'] === 'Khác') {
            const otherInput = formElement.querySelector('#addPetOtherSpeciesInput, #editPetOtherSpeciesInput');
            if (otherInput && otherInput.value.trim() !== '') {
                obj['LoaiNguonGoc'] = otherInput.value.trim();
            }
        }
        return obj;
    }

    // Helper: Fill form fields
    function fillForm(formElement, data) {
        Object.keys(data).forEach(key => {
            // Find key in camelCase or TitleCase
            let formField = formElement.elements[key];
            if (!formField) {
                // Try casing difference
                const upperKey = key.charAt(0).toUpperCase() + key.slice(1);
                formField = formElement.elements[upperKey];
            }

            if (formField) {
                if ((key === 'ngayCuuHo' || key === 'NgayCuuHo') && data[key]) {
                    formField.value = data[key].substring(0, 10);
                } else {
                    formField.value = data[key] === null ? '' : data[key];
                }
            }
        });
    }

    // Load pets with dynamic filters
    async function loadPets() {
        const search = document.getElementById('filterSearch').value.trim();
        const species = document.getElementById('filterSpecies').value;
        const adoptionStatus = document.getElementById('filterAdoptionStatus').value;

        const tableBody = document.getElementById('petTableBody');
        tableBody.innerHTML = `<tr><td colspan="8" class="text-center py-4 text-muted"><div class="spinner-border spinner-border-sm text-primary me-2"></div> Đang tải danh sách...</td></tr>`;

        try {
            const params = new URLSearchParams();
            if (search) params.append('q', search);
            if (species) params.append('loai', species);
            if (adoptionStatus) params.append('trangthai', adoptionStatus);

            const res = await fetch(`/api/pets?${params.toString()}`);
            const json = await res.json();

            if (json.success) {
                currentPets = json.data || [];
                renderPetsTable(currentPets);
                updateStats(currentPets);
            } else {
                tableBody.innerHTML = `<tr><td colspan="8" class="text-center py-4 text-danger">Lỗi: ${json.message}</td></tr>`;
            }
        } catch (err) {
            console.error(err);
            tableBody.innerHTML = `<tr><td colspan="8" class="text-center py-4 text-danger">Không thể kết nối đến máy chủ.</td></tr>`;
        }
    }

    // Render Table Rows
    function renderPetsTable(pets) {
        const tableBody = document.getElementById('petTableBody');
        if (pets.length === 0) {
            tableBody.innerHTML = `<tr><td colspan="8" class="text-center py-4 text-muted">Không tìm thấy thú cưng nào.</td></tr>`;
            return;
        }

        tableBody.innerHTML = pets.map(pet => {
            const avatarUrl = pet.anhChinh || 'https://images.unsplash.com/photo-1543466835-00a7907e9de1?auto=format&fit=crop&q=80&w=200';
            const genderBadge = pet.gioiTinh === 'Đực' ? '<span class="text-primary"><i class="bi bi-gender-male"></i> Đực</span>' : pet.gioiTinh === 'Cái' ? '<span class="text-danger"><i class="bi bi-gender-female"></i> Cái</span>' : '<span class="text-muted">Chưa rõ</span>';
            const ageDisplay = pet.giaTriTuoi ? `${pet.giaTriTuoi} ${pet.donViTuoi || 'Tuổi'}` : 'Chưa rõ';

            // Adoption Status Badges
            let adoptBadge = '<span class="db-badge db-badge-info">Chưa nhận nuôi</span>';
            if (pet.trangThaiNhanNuoi === 'Đang xử lý') {
                adoptBadge = '<span class="db-badge db-badge-warning">Đang xử lý</span>';
            } else if (pet.trangThaiNhanNuoi === 'Đã nhận nuôi') {
                adoptBadge = '<span class="db-badge db-badge-success">Đã nhận nuôi</span>';
            }

            // Rescue Status Badges
            let rescueBadge = '<span class="db-badge db-badge-secondary">ĐANG CHỜ</span>';
            if (pet.trangThaiCuuHo === 'ĐÃ NHẬN') {
                rescueBadge = '<span class="db-badge db-badge-info">ĐÃ NHẬN</span>';
            } else if (pet.trangThaiCuuHo === 'ĐANG CỨU HỘ') {
                rescueBadge = '<span class="db-badge db-badge-warning">ĐANG CỨU HỘ</span>';
            } else if (pet.trangThaiCuuHo === 'ĐÃ HOÀN THÀNH') {
                rescueBadge = '<span class="db-badge db-badge-success">HOÀN THÀNH</span>';
            }

            return `
              <tr>
                <td>
                  <div class="db-pet-avatar">
                    <img src="${avatarUrl}" alt="${pet.tenThuCung}" onerror="this.src='https://images.unsplash.com/photo-1543466835-00a7907e9de1?auto=format&fit=crop&q=80&w=200'" />
                  </div>
                </td>
                <td><strong class="text-dark">${pet.tenThuCung}</strong></td>
                <td>
                  <div class="font-semibold">${pet.loaiNguonGoc}</div>
                  <small class="text-muted">${pet.giongThuCung || 'Lai / Khác'}</small>
                </td>
                <td>
                  <div>${ageDisplay}</div>
                  <small>${genderBadge}</small>
                </td>
                <td>
                  <span class="text-truncate d-inline-block" style="max-width: 150px;" title="${pet.tinhTrangSucKhoe || 'Bình thường'}">
                    ${pet.tinhTrangSucKhoe || '<span class="text-muted">Bình thường</span>'}
                  </span>
                </td>
                <td>${rescueBadge}</td>
                <td>${adoptBadge}</td>
                <td>
                  <div class="d-flex gap-2">
                    <button class="btn btn-sm btn-outline-success border-0" onclick="openRescueCostsModal(${pet.maThuCung}, '${pet.tenThuCung}')" title="Quản lý chi phí">
                      <i class="bi bi-cash-stack"></i>
                    </button>
                    <button class="btn btn-sm btn-outline-primary border-0" onclick="openEditModal(${pet.maThuCung})" title="Chỉnh sửa">
                      <i class="bi bi-pencil-fill"></i>
                    </button>
                    <button class="btn btn-sm btn-outline-danger border-0" onclick="openDeleteModal(${pet.maThuCung}, '${pet.tenThuCung}')" title="Xóa">
                      <i class="bi bi-trash3-fill"></i>
                    </button>
                  </div>
                </td>
              </tr>
            `;
        }).join('');
    }

    // Update Top Stat Cards dynamically based on full list
    function updateStats(pets) {
        document.getElementById('statTotalPets').textContent = pets.length;
        const dogs = pets.filter(p => p.loaiNguonGoc === 'Chó').length;
        const cats = pets.filter(p => p.loaiNguonGoc === 'Mèo').length;
        const adopted = pets.filter(p => p.trangThaiNhanNuoi === 'Đã nhận nuôi').length;

        document.getElementById('statDogs').textContent = dogs;
        document.getElementById('statCats').textContent = cats;
        document.getElementById('statAdopted').textContent = adopted;
    }

    // POST - Add Pet
    async function handleAddPet(e) {
        e.preventDefault();
        const data = getFormData(e.target);

        try {
            const res = await fetch('/api/pets', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });
            const json = await res.json();

            if (json.success) {
                dbToast('🎉 Thêm thú cưng mới thành công!');
                addPetModal.hide();
                e.target.reset();
                loadPets();
            } else {
                alert('Lỗi: ' + json.message);
            }
        } catch (err) {
            console.error(err);
            alert('Lỗi kết nối máy chủ khi thêm thú cưng.');
        }
    }

    // Open Edit Modal and fill data
    function openEditModal(id) {
        const pet = currentPets.find(p => p.maThuCung === id);
        if (!pet) return;

        const form = document.getElementById('editPetForm');
        fillForm(form, pet);

        // Handle custom animal species in Edit mode
        const species = pet.loaiNguonGoc;
        const editSelect = document.getElementById('editPetSpeciesSelect');
        const editOtherContainer = document.getElementById('editPetOtherSpeciesContainer');
        const editOtherInput = document.getElementById('editPetOtherSpeciesInput');

        if (editSelect && editOtherContainer && editOtherInput) {
            if (species !== 'Chó' && species !== 'Mèo') {
                editSelect.value = 'Khác';
                editOtherContainer.classList.remove('d-none');
                editOtherInput.value = species;
                editOtherInput.setAttribute('required', 'required');
            } else {
                editSelect.value = species;
                editOtherContainer.classList.add('d-none');
                editOtherInput.value = '';
                editOtherInput.removeAttribute('required');
            }
        }
        
        // Update image preview
        document.getElementById('editPetImagePreview').src = pet.anhChinh || 'https://images.unsplash.com/photo-1543466835-00a7907e9de1?auto=format&fit=crop&q=80&w=200';
        document.getElementById('editPetImageUrl').value = pet.anhChinh || '';
        document.getElementById('editPetImageFile').value = '';
        
        editPetModal.show();
    }

    // PUT - Edit Pet
    async function handleEditPet(e) {
        e.preventDefault();
        const data = getFormData(e.target);
        const id = data.MaThuCung || data.maThuCung;

        try {
            const res = await fetch(`/api/pets/${id}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });
            const json = await res.json();

            if (json.success) {
                dbToast('✏️ Cập nhật thông tin thành công!');
                editPetModal.hide();
                loadPets();
            } else {
                alert('Lỗi: ' + json.message);
            }
        } catch (err) {
            console.error(err);
            alert('Lỗi kết nối máy chủ khi cập nhật.');
        }
    }

    // Open Delete Modal
    function openDeleteModal(id, name) {
        deleteTargetId = id;
        document.getElementById('deletePetName').textContent = name;
        deletePetModal.show();
    }

    // DELETE - Delete Pet
    async function handleDeletePet() {
        if (!deleteTargetId) return;

        try {
            const res = await fetch(`/api/pets/${deleteTargetId}`, {
                method: 'DELETE'
            });
            const json = await res.json();

            if (json.success) {
                dbToast('🗑️ Đã xóa hồ sơ thú cưng thành công.');
                deletePetModal.hide();
                loadPets();
            } else {
                alert('Lỗi: ' + json.message);
            }
        } catch (err) {
            console.error(err);
            alert('Lỗi kết nối máy chủ khi xóa.');
        } finally {
            deleteTargetId = null;
        }
    }

    // ── Rescue Costs Operations ──
    let currentRescueCosts = [];

    window.openRescueCostsModal = async function(petId, petName) {
        currentPetCostsId = petId;
        document.getElementById('costsPetName').textContent = petName;
        
        // Reset form
        const form = document.getElementById('addRescueCostForm');
        form.reset();
        const dateInput = form.querySelector('input[name="NgayChiTieu"]');
        if (dateInput) {
            dateInput.value = new Date().toISOString().substring(0, 10);
        }

        // Load costs
        await loadRescueCosts(petId);
        
        manageRescueCostsModal.show();
    }

    async function loadRescueCosts(petId) {
        const tbody = document.getElementById('rescueCostsTableBody');
        tbody.innerHTML = '<tr><td colspan="4" class="text-center py-3 text-muted"><div class="spinner-border spinner-border-sm text-primary me-2"></div> Đang tải...</td></tr>';
        
        try {
            const res = await fetch(`/api/pets/${petId}/costs`);
            const json = await res.json();
            
            if (json.success) {
                currentRescueCosts = json.data || [];
                renderRescueCostsTable(currentRescueCosts);
            } else {
                tbody.innerHTML = `<tr><td colspan="4" class="text-center py-3 text-danger">Lỗi: ${json.message}</td></tr>`;
            }
        } catch (err) {
            console.error(err);
            tbody.innerHTML = '<tr><td colspan="4" class="text-center py-3 text-danger">Lỗi kết nối máy chủ.</td></tr>';
        }
    }

    function renderRescueCostsTable(costs) {
        const tbody = document.getElementById('rescueCostsTableBody');
        const totalSumEl = document.getElementById('costsTotalSum');
        
        if (costs.length === 0) {
            tbody.innerHTML = '<tr><td colspan="4" class="text-center py-3 text-muted">Chưa phát sinh chi phí nào cho bé này.</td></tr>';
            totalSumEl.textContent = '0 đ';
            return;
        }

        let total = 0;
        tbody.innerHTML = costs.map(c => {
            total += c.soTien;
            const dateStr = new Date(c.ngayChiTieu).toLocaleDateString("vi-VN");
            
            let badgeClass = "bg-primary-subtle text-primary border border-primary-subtle";
            if (c.loaiChiPhi === 'Viện phí') badgeClass = "bg-danger-subtle text-danger border border-danger-subtle";
            else if (c.loaiChiPhi === 'Thức ăn') badgeClass = "bg-success-subtle text-success border border-success-subtle";
            else if (c.loaiChiPhi === 'Vận chuyển') badgeClass = "bg-warning-subtle text-warning border border-warning-subtle";

            const notesHtml = c.mucDichChiTiet ? `<div class="text-muted small mt-1 text-truncate" style="max-width: 180px;" title="${escapeHtml(c.mucDichChiTiet)}">${escapeHtml(c.mucDichChiTiet)}</div>` : '';

            return `
                <tr>
                    <td>
                        <span class="badge ${badgeClass}">${escapeHtml(c.loaiChiPhi)}</span>
                        ${notesHtml}
                    </td>
                    <td class="font-bold">${c.soTien.toLocaleString("vi-VN")}đ</td>
                    <td class="small text-muted">${dateStr}</td>
                    <td>
                        <button class="btn btn-sm btn-outline-danger border-0 p-1" onclick="deleteRescueCost(${c.maChiPhi})" title="Xóa">
                            <i class="bi bi-trash-fill"></i>
                        </button>
                    </td>
                </tr>
            `;
        }).join('');

        totalSumEl.textContent = total.toLocaleString("vi-VN") + ' đ';
    }

    async function handleAddRescueCost(e) {
        e.preventDefault();
        if (!currentPetCostsId) return;

        const formData = new FormData(e.target);
        const data = {};
        formData.forEach((value, key) => {
            if (key === 'SoTien') data[key] = parseFloat(value);
            else data[key] = value;
        });

        try {
            dbToast('💸 Đang lưu chi phí...');
            const res = await fetch(`/api/pets/${currentPetCostsId}/costs`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });
            const json = await res.json();

            if (json.success) {
                dbToast('✔️ Thêm chi phí thành công!');
                e.target.reset();
                const dateInput = e.target.querySelector('input[name="NgayChiTieu"]');
                if (dateInput) {
                    dateInput.value = new Date().toISOString().substring(0, 10);
                }
                await loadRescueCosts(currentPetCostsId);
            } else {
                alert('Lỗi: ' + json.message);
            }
        } catch (err) {
            console.error(err);
            alert('Lỗi khi thêm chi phí cứu hộ.');
        }
    }

    window.deleteRescueCost = async function(costId) {
        if (!confirm('Bạn có chắc chắn muốn xóa khoản chi phí này?')) return;

        try {
            dbToast('🗑️ Đang xóa...');
            const res = await fetch(`/api/pets/costs/${costId}`, {
                method: 'DELETE'
            });
            const json = await res.json();

            if (json.success) {
                dbToast('✔️ Đã xóa chi phí thành công.');
                await loadRescueCosts(currentPetCostsId);
            } else {
                alert('Lỗi: ' + json.message);
            }
        } catch (err) {
            console.error(err);
            alert('Lỗi kết nối khi xóa chi phí.');
        }
    }

    function escapeHtml(str) {
        if (!str) return "";
        return str
            .replace(/&/g, "&amp;")
            .replace(/</g, "&lt;")
            .replace(/>/g, "&gt;")
            .replace(/"/g, "&quot;")
            .replace(/'/g, "&#039;");
    }
  </script>
}
