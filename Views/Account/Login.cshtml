    <script>
        // DOM Integrity Diagnostics
        (function() {
            setTimeout(function() {
                var signinContainer = document.getElementById("signin-box-container");
                var rightPanel = document.querySelector(".auth-card-right");
                var report = [];
                
                if (!rightPanel) {
                    report.push("Error: .auth-card-right not found");
                } else {
                    report.push(".auth-card-right found, innerHTML length: " + rightPanel.innerHTML.trim().length);
                    var style = window.getComputedStyle(rightPanel);
                    report.push(".auth-card-right visibility: " + style.visibility + ", display: " + style.display + ", opacity: " + style.opacity);
                }
                
                if (!signinContainer) {
                    report.push("Error: #signin-box-container not found");
                } else {
                    report.push("#signin-box-container found, classes: " + signinContainer.className);
                    var styleBox = window.getComputedStyle(signinContainer);
                    report.push("#signin-box-container display: " + styleBox.display + ", visibility: " + styleBox.visibility + ", height: " + styleBox.height);
                }
                
                console.log("DOM Diagnostic Report:", report);
                if (report.some(r => r.indexOf("Error") !== -1 || r.indexOf("length: 0") !== -1 || r.indexOf("display: none") !== -1)) {
                    var errBox = document.getElementById("js-error-reporter");
                    var errMsg = document.getElementById("js-error-msg");
                    if (errBox && errMsg) {
                        errBox.style.display = "block";
                        errMsg.innerHTML += "<br/><strong>DOM Diagnostics:</strong><br/>" + report.join("<br/>");
                    }
                }
            }, 500);
        })();
    </script>
