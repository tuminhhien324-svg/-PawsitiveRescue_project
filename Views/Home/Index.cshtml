    <!-- Mock Video Modal -->
    <div
      class="modal fade"
      id="videoModal"
      tabindex="-1"
      aria-labelledby="videoModalLabel"
      aria-hidden="true"
    >
      <div class="modal-dialog modal-dialog-centered modal-lg">
        <div
          class="modal-content border border-3 border-dark rounded-md"
          style="background-color: var(--pawsitive-surface)"
        >
          <div class="modal-header border-0 pb-0">
            <h5 class="modal-title brand-font fs-4" id="videoModalLabel">
              🐾 Hành trình cứu hộ & bảo trợ
            </h5>
            <button
              type="button"
              class="btn-close"
              data-bs-dismiss="modal"
              aria-label="Close"
            ></button>
          </div>
          <div class="modal-body p-4">
            <div
              class="ratio ratio-16x9 border border-2 border-dark rounded-default overflow-hidden shadow-flat"
            >
              <iframe
                src="https://www.youtube.com/embed/eqL2bPVuqcM"
                title="YouTube video player"
                frameborder="0"
                allow="
                  accelerometer;
                  autoplay;
                  clipboard-write;
                  encrypted-media;
                  gyroscope;
                  picture-in-picture;
                  web-share;
                "
                allowfullscreen
              ></iframe>
            </div>
            <p class="mt-3 text-muted small text-center m-0">
              Chúng tôi cam kết 100% các đóng góp đều được đưa trực tiếp vào quỹ
              cứu trợ động vật.
            </p>
          </div>
        </div>
      </div>
