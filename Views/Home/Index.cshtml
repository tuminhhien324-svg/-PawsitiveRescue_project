    <!-- Bootstrap 5 JS Bundle -->
    <script>
      document.addEventListener("DOMContentLoaded", () => {
        loadFeaturedPets();
      });

      async function loadFeaturedPets() {
        const container = document.getElementById("homepage-featured-pets");
        try {
          const res = await fetch("/api/pets");
          const json = await res.json();
          if (json.success && json.data) {
            const availablePets = json.data.filter(p => p.trangThaiNhanNuoi !== "Đã nhận nuôi");
            if (availablePets.length === 0) {
              container.innerHTML = `
                <div class="col-12 text-center py-5">
                  <span class="fs-1">💖</span>
                  <h3 class="brand-font mt-3">Tất cả các bé đã được nhận nuôi</h3>
                  <p class="text-muted">Xin cảm ơn tấm lòng hảo tâm của các bạn!</p>
                </div>
              `;
              return;
            }
            
            const mainPet = availablePets[0];
            const otherPets = availablePets.slice(1, 5);

            const mainAvatarUrl = mainPet.anhChinh || "https://images.unsplash.com/photo-1552053831-71594a27632d?auto=format&fit=crop&q=80&w=600";
            const mainAgeDisplay = mainPet.giaTriTuoi ? `${mainPet.giaTriTuoi} ${mainPet.donViTuoi || 'Tuổi'}` : 'Chưa rõ';

            let mainCardHtml = `
              <div class="col-lg-6">
                <div class="card-pawsitive h-100 d-flex flex-column justify-content-between p-4" style="min-height: 480px">
                  <div class="pet-frame ratio ratio-16x9 mb-4">
                    <img src="${mainAvatarUrl}" alt="${mainPet.tenThuCung}" />
                    <div class="position-absolute top-0 end-0 m-3 bg-white text-danger rounded-full border border-2 border-dark d-flex align-items-center justify-content-center" style="width: 42px; height: 42px">
                      <i class="bi bi-heart-fill"></i>
                    </div>
                  </div>
                  <div>
                    <div class="d-flex gap-2 mb-2">
                      <span class="badge badge-pawsitive badge-pawsitive-primary">${mainPet.loaiNguonGoc}</span>
                      <span class="badge badge-pawsitive badge-pawsitive-secondary">${mainPet.giongThuCung || 'Ngoại lai'}</span>
                    </div>
                    <h3 class="brand-font mb-2">${mainPet.tenThuCung} - ${mainAgeDisplay}</h3>
                    <p class="text-muted mb-4">${mainPet.moTa || 'Đang chờ tìm mái ấm mới...'}</p>
                  </div>
                  <a class="btn btn-pawsitive btn-pawsitive-secondary w-100 rounded-full justify-content-center" href="/Home/Detail?id=${mainPet.maThuCung}">
                    Gặp ${mainPet.tenThuCung}
                  </a>
                </div>
              </div>
            `;

            let otherCardsHtml = `
              <div class="col-lg-6">
                <div class="row g-4">
            `;

            otherPets.forEach(pet => {
              const avatarUrl = pet.anhChinh || "https://images.unsplash.com/photo-1543466835-00a7907e9de1?auto=format&fit=crop&q=80&w=300";
              const ageDisplay = pet.giaTriTuoi ? `${pet.giaTriTuoi} ${pet.donViTuoi || 'Tuổi'}` : 'Chưa rõ';
              otherCardsHtml += `
                <div class="col-6">
                  <div class="card-pawsitive p-3 d-flex flex-column">
                    <div class="pet-frame mb-3 ratio ratio-1x1" style="overflow:hidden; border-radius: 1.25rem;">
                      <img src="${avatarUrl}" alt="${pet.tenThuCung}" style="width:100%; height:100%; object-fit:cover;" />
                      <span class="position-absolute top-0 start-0 m-2 badge bg-dark text-white rounded-pill px-2 py-1 small">${pet.loaiNguonGoc}</span>
                    </div>
                    <h4 class="brand-font h5 mb-1 text-truncate">${pet.tenThuCung}</h4>
                    <p class="small text-muted mb-3 text-truncate">
                      ${ageDisplay} • ${pet.giongThuCung || 'Dòng lai'}
                    </p>
                    <a class="btn btn-pawsitive btn-pawsitive-secondary rounded-full py-1 justify-content-center small" href="/Home/Detail?id=${pet.maThuCung}">
                      Nhận nuôi
                    </a>
                  </div>
                </div>
              `;
            });

            otherCardsHtml += `
                </div>
              </div>
            `;

            container.innerHTML = mainCardHtml + otherCardsHtml;
          } else {
            container.innerHTML = `<div class="text-center py-5 text-danger">Lỗi tải dữ liệu thú cưng.</div>`;
          }
        } catch (err) {
          console.error(err);
          container.innerHTML = `<div class="text-center py-5 text-danger">Lỗi kết nối máy chủ.</div>`;
        }
      }
    </script>
