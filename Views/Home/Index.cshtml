@{
    ViewData["Title"] = "Trang chủ";
    Layout = "_Layout";
}

<!-- Hero Section -->
    <header class="py-5" style="background-color: var(--pawsitive-surface-low)">
      <div class="container py-lg-4">
        <div class="row align-items-center g-5">
          <!-- Hero Text -->
          <div class="col-lg-6 text-center text-lg-start">
            <span
              class="badge badge-pawsitive badge-pawsitive-secondary mb-3 py-2 px-3"
            >
              🐾 HÀNH TRÌNH YÊU THƯƠNG
            </span>
            <h1
              class="display-4 mb-4 brand-font"
              style="font-weight: 800; font-size: 3.2rem"
            >
              Tìm gia đình mới cho những
              <span class="highlight-primary">người bạn</span> bốn chân
            </h1>
            <p
              class="lead mb-4"
              style="
                font-size: 1.15rem;
                color: var(--pawsitive-on-surface-variant);
              "
            >
              Mỗi chú chó, chú mèo đều xứng đáng có một mái ấm tràn ngập tình
              thương. Hãy cùng Pawsitive Rescue viết tiếp câu chuyện hạnh phúc
              của chúng.
            </p>
            <div
              class="d-flex flex-column flex-sm-row justify-content-center justify-content-lg-start gap-3"
            >
              <a
                class="btn btn-pawsitive btn-pawsitive-primary rounded-full px-4 py-3 fs-5"
                asp-controller="Home" asp-action="Adopt"
              >
                Nhận nuôi ngay 🐾
              </a>
              <button
                class="btn btn-pawsitive btn-pawsitive-secondary rounded-full px-4 py-3 fs-5"
                data-bs-toggle="modal"
                data-bs-target="#videoModal"
              >
                <i class="bi bi-play-circle-fill me-1"></i> Xem video
              </button>
            </div>
          </div>
          <!-- Hero Image -->
          <div class="col-lg-6">
            <div class="position-relative">
              <!-- Decorative organic frame for cartoon tactile feel -->
              <div
                class="p-3 bg-success rounded-md border border-3 border-dark shadow-flat transform rotate-3"
                style="background-color: #8bbfa9 !important"
              >
                <img
                  src="https://images.unsplash.com/photo-1548199973-03cce0bbc87b?auto=format&fit=crop&q=80&w=800"
                  alt="Puppies playing"
                  class="img-fluid rounded-default border border-2 border-dark"
                />
              </div>
              <!-- Interactive Floating Heart -->
              <div
                class="position-absolute bottom-0 start-0 translate-middle bg-danger text-white rounded-full border border-2 border-dark d-flex align-items-center justify-content-center cursor-pointer shadow-flat hover-scale"
                style="width: 56px; height: 56px; transform: rotate(-15deg)"
              >
                <i class="bi bi-heart-fill fs-4"></i>
              </div>
            </div>
          </div>
        </div>
      </div>
    </header>

    <!-- Section 2: Our Story -->
    <section class="py-5 bg-white">
      <div class="container py-lg-5">
        <div class="row align-items-center g-5">
          <!-- Story Visual Grid -->
          <div class="col-lg-6">
            <div class="row g-3">
              <div class="col-6">
                <div
                  class="border border-2 border-dark rounded-md overflow-hidden pet-frame shadow-flat ratio ratio-1x1 mb-3"
                >
                  <img
                    src="https://images.unsplash.com/photo-1517849845537-4d257902454a?auto=format&fit=crop&q=80&w=300"
                    alt="Puppy"
                  />
                </div>
                <div
                  class="p-4 border border-2 border-dark rounded-md text-white text-center shadow-flat"
                  style="background-color: var(--pawsitive-secondary)"
                >
                  <h3 class="brand-font h1 mb-1">500+</h3>
                  <span class="small font-bold">Bé đã tìm được nhà</span>
                </div>
              </div>
              <div class="col-6 pt-4">
                <div
                  class="p-4 border border-2 border-dark rounded-md text-white text-center shadow-flat mb-3"
                  style="background-color: var(--pawsitive-primary-vibrant)"
                >
                  <h3 class="brand-font h1 mb-1">100+</h3>
                  <span class="small font-bold">Tình nguyện viên</span>
                </div>
