@{
    ViewData["Title"] = "Nhận nuôi";
    Layout = "_Layout";
}

<!-- Banner / Hero Section -->
    <header class="py-5" style="background-color: var(--pawsitive-background)">
      <div class="container">
        <div class="row align-items-center g-5">
          <div class="col-lg-6">
            <span
              class="text-danger fw-bold small text-uppercase"
              style="letter-spacing: 0.1em"
              >Tìm Người Bạn</span
            >
            <h1 class="display-4 mb-4 brand-font" style="font-weight: 800">
              Bốn Chân Của Bạn
            </h1>
            <p class="lead mb-4 text-muted" style="font-size: 1.1rem">
              Hàng ngàn chú chó, mèo đang chờ đợi một mái ấm yêu thương. Hãy
              trao cho các em một cơ hội thứ hai.
            </p>
          </div>
          <div class="col-lg-6">
            <div class="position-relative">
              <div
                class="p-3 bg-warning rounded-md border border-3 border-dark shadow-flat transform -rotate-2"
                style="background-color: #fbd38d !important"
              >
                <img
                  src="https://images.unsplash.com/photo-1583511655857-d19b40a7a54e?auto=format&fit=crop&q=80&w=800"
                  alt="Happy dogs"
                  class="img-fluid rounded-default border border-2 border-dark"
                />
              </div>
              <!-- Floating Heart -->
              <div
                class="position-absolute top-0 end-0 translate-middle bg-danger text-white rounded-full border border-2 border-dark d-flex align-items-center justify-content-center cursor-pointer shadow-flat hover-scale"
                style="width: 52px; height: 52px"
              >
                <i class="bi bi-heart-fill fs-5"></i>
              </div>
            </div>
          </div>
        </div>
      </div>
    </header>

    <!-- Advocacy Section -->
    <section class="container my-5">
      <div
        class="p-4 border border-2 border-dark rounded-md shadow-flat"
        style="background-color: var(--pawsitive-secondary-container)"
      >
        <div class="row align-items-center">
          <div class="col-lg-9 mb-3 mb-lg-0 text-dark">
            <h2
              class="brand-font fs-5 mb-2"
              style="
                color: var(--pawsitive-on-secondary-container);
                font-weight: 700;
              "
            >
              Tại sao nên nhận nuôi thay vì mua?
            </h2>
            <p class="small m-0 text-muted">
              Nhận nuôi không chỉ cứu sống một sinh mạng mà còn giúp ngăn chặn
              nạn nhân giống vô nhân đạo. Mỗi lần bạn nhận nuôi, bạn dành chỗ
              cho một bé khác được cứu hộ tại trạm.
            </p>
          </div>
          <div class="col-lg-3 text-lg-end">
            <button
              class="btn btn-pawsitive btn-pawsitive-secondary rounded-full py-2"
              data-bs-toggle="modal"
              data-bs-target="#advocacyModal"
            >
              Tìm hiểu thêm
            </button>
          </div>
        </div>
      </div>
    </section>

    <!-- Filter & Catalog Section -->
    <main class="container mb-5">
      <!-- Filter Panel -->
      <div
        class="p-4 bg-white border border-2 border-dark rounded-md shadow-flat mb-5"
      >
        <!-- Species selector tabs -->
        <div class="d-flex flex-wrap gap-3 mb-4">
          <button
            class="btn btn-pawsitive btn-pawsitive-primary rounded-full px-4 active"
            id="filter-all"
          >
            🐾 Tất cả
          </button>
          <button
            class="btn btn-pawsitive btn-pawsitive-secondary rounded-full px-4"
            id="filter-dog"
          >
            🐶 Chó
          </button>
          <button
            class="btn btn-pawsitive btn-pawsitive-secondary rounded-full px-4"
            id="filter-cat"
          >
            🐱 Mèo
          </button>
          <button
            class="btn btn-pawsitive btn-pawsitive-secondary rounded-full px-4"
            id="filter-other"
          >
            🦜 Khác
          </button>
        </div>

        <!-- Advanced Filters Row -->
        <div class="row g-3">
          <div class="col-md-3">
            <select
              class="form-select form-control-pawsitive"
              id="select-age"
              aria-label="Độ tuổi"
            >
              <option value="">Độ tuổi: Tất cả</option>
              <option value="baby">Sơ sinh (0 - 6 tháng)</option>
              <option value="young">Trưởng thành nhỏ (6 - 18 tháng)</option>
              <option value="adult">Trưởng thành lớn (> 18 tháng)</option>
            </select>
          </div>
          <div class="col-md-3">
            <select
              class="form-select form-control-pawsitive"
              id="select-gender"
              aria-label="Giới tính"
            >
              <option value="">Giới tính: Tất cả</option>
              <option value="male">Đực</option>
              <option value="female">Cái</option>
            </select>
          </div>
          <div class="col-md-3">
            <select
              class="form-select form-control-pawsitive"
              id="select-size"
              aria-label="Kích thước"
            >
              <option value="">Kích thước: Tất cả</option>
              <option value="small">Nhỏ (&lt; 5kg)</option>
              <option value="medium">Vừa (5 - 15kg)</option>
              <option value="large">Lớn (&gt; 15kg)</option>
            </select>
          </div>
          <div class="col-md-3">
            <div class="input-group">
              <span
                class="input-group-text bg-white border-2 border-end-0 border-dark rounded-start-1"
                style="border-radius: 1rem 0 0 1rem"
                ><i class="bi bi-search"></i
              ></span>
              <input
                type="text"
                class="form-control form-control-pawsitive border-start-0 rounded-start-0"
                id="search-name"
                placeholder="Tìm tên pet..."
                style="border-radius: 0 1rem 1rem 0"
              />
            </div>
          </div>
        </div>
      </div>

