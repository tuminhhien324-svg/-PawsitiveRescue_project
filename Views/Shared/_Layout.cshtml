<!doctype html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Pawsitive Rescue</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/style.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <nav class="navbar navbar-expand-lg pawsitive-navbar sticky-top">
        <div class="container-fluid max-container">
            <a class="pawsitive-logo" asp-controller="Home" asp-action="Index">🐾 Pawsitive Rescue</a>
            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#pawsitiveNavbar" aria-controls="pawsitiveNavbar" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse justify-content-end" id="pawsitiveNavbar">
                <ul class="navbar-nav align-items-lg-center gap-3">
                    <li class="nav-item"><a class="pawsitive-nav-link" asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                    <li class="nav-item"><a class="pawsitive-nav-link" asp-controller="Home" asp-action="Rescue">Cứu hộ</a></li>
                    <li class="nav-item"><a class="pawsitive-nav-link" asp-controller="Home" asp-action="Adopt">Nhận nuôi</a></li>
                    <li class="nav-item"><a class="pawsitive-nav-link" asp-controller="Home" asp-action="Blogs">Blogs</a></li>
                    <li class="nav-item"><a class="pawsitive-nav-link" asp-controller="Home" asp-action="Volunteer">Tình nguyện</a></li>
                    <li class="nav-item ms-lg-2">
                        <a class="btn btn-pawsitive btn-pawsitive-secondary rounded-full py-2" asp-controller="Home" asp-action="Donate">
                            <i class="bi bi-heart-fill text-danger"></i> Quyên góp
                        </a>
                    </li>
                    <li class="nav-item ms-lg-1">
                        <a class="btn btn-pawsitive btn-pawsitive-sos rounded-full py-2 text-white" asp-controller="Home" asp-action="Rescue">
                            <i class="bi bi-exclamation-triangle-fill"></i> SOS
                        </a>
                    </li>
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        @if (User.IsInRole("Quản trị viên"))
                        {
                            <li class="nav-item">
                                <a class="pawsitive-nav-link text-primary font-bold" asp-controller="Admin" asp-action="Index">
                                    <i class="bi bi-speedometer2"></i> Quản trị
                                </a>
                            </li>
                        }
                        <li class="nav-item ms-lg-2">
                            <a class="d-inline-block border border-2 border-dark rounded-full overflow-hidden" asp-controller="Account" asp-action="Profile" style="width: 42px; height: 42px" title="Trang cá nhân">
                                <img src="https://cdn-icons-png.flaticon.com/512/149/149071.png" alt="Avatar" class="w-100 h-100" style="object-fit: cover" />
                            </a>
                        </li>
                        <li class="nav-item ms-lg-1">
                            <a class="btn btn-pawsitive btn-pawsitive-secondary rounded-full py-2" href="javascript:void(0)" onclick="pawsitiveLogout();" title="Đăng xuất">
                                <i class="bi bi-box-arrow-right"></i> Đăng xuất
                            </a>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item ms-lg-2">
                            <a class="btn btn-pawsitive btn-pawsitive-primary rounded-full py-2 px-3 text-white" asp-controller="Account" asp-action="Login">
                                <i class="bi bi-box-arrow-in-right"></i> Đăng nhập
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    @RenderBody()

    <footer class="py-5 text-dark" style="background-color: #e8e6db; border-top: 2px solid var(--pawsitive-surface-highest);">
        <div class="container py-lg-4 text-center">
            <p class="small text-muted mb-2">&copy; 2026 Pawsitive Rescue. Bảo lưu mọi quyền.</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/auth.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
