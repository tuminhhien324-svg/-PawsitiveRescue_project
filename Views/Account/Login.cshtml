@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập / Đăng ký - Pawsitive Rescue</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/style.css" asp-append-version="true" />
    <style>
        body {
            background-color: #fefdf9 !important;
            font-family: "Comfortaa", cursive, sans-serif;
            color: #2d3748;
        }
        .auth-wrapper {
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }
        .auth-container {
            display: flex;
            justify-content: center;
            align-items: center;
            flex: 1;
            padding: 3rem 1.5rem;
        }
        .auth-card {
            display: flex;
            width: 100%;
            max-width: 1000px;
            background-color: #ffffff;
            border: 2px solid #2d3748;
            border-radius: 24px;
            box-shadow: 6px 6px 0px #2d3748;
            overflow: hidden;
            min-height: 580px;
        }
        .auth-card-left {
            width: 45%;
            background-color: #fcf9ee;
            padding: 3rem 2.5rem;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            position: relative;
            border-right: 2px solid #2d3748;
            transition: background-color 0.3s ease;
        }
        .auth-card-left.signup-mode {
            background-color: #c5e4ff !important;
        }
        .auth-card-right {
            flex: 1;
            padding: 3rem;
            display: flex;
            flex-direction: column;
            justify-content: center;
            background-color: #ffffff;
        }
        .auth-input-custom {
            border: 2px solid #2d3748 !important;
            background-color: #fefdf9 !important;
            border-radius: 10px !important;
            padding: 0.7rem 1rem !important;
            font-weight: 500;
            transition: all 0.2s ease;
        }
        .auth-input-custom:focus {
            border-color: #d97706 !important;
            box-shadow: none !important;
            background-color: #ffffff !important;
        }
        .pref-card {
            border: 2px solid #2d3748;
            border-radius: 16px;
            padding: 15px 5px;
            text-align: center;
            cursor: pointer;
            background: #fefdf9;
            box-shadow: 3px 3px 0px #2d3748;
            transition: all 0.2s ease;
            user-select: none;
        }
        .pref-card:hover {
            transform: translate(-1px, -1px);
            box-shadow: 4px 4px 0px #2d3748;
        }
        .pref-card.active-pref {
            background: #feebc8 !important;
            border-color: #d97706 !important;
            box-shadow: 2px 2px 0px #d97706 !important;
            transform: translate(1px, 1px);
        }
        .avatar-select-item {
            width: 60px;
            height: 60px;
            border-radius: 50%;
            border: 3px solid transparent;
            overflow: hidden;
            cursor: pointer;
            padding: 1px;
            transition: all 0.2s ease;
        }
        .avatar-select-item.active-avatar {
            border-color: #d97706 !important;
            transform: scale(1.08);
        }
        .avatar-select-item img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            border-radius: 50%;
        }
        .otp-input-box {
            width: 45px;
            height: 45px;
            border-radius: 50% !important;
            border: 2px solid #2d3748 !important;
            background-color: #fefdf9 !important;
            font-size: 1.2rem;
            font-weight: 700;
            text-align: center;
            transition: all 0.2s ease;
        }
        .otp-input-box:focus {
            border-color: #d97706 !important;
            background-color: #ffffff !important;
            box-shadow: none !important;
        }
        .brand-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            width: 100%;
            max-width: 600px;
            margin: 0 auto 1.5rem auto;
            padding: 0 1rem;
        }
        .brand-header-logo {
            font-family: var(--font-headlines);
            font-size: 1.4rem;
            font-weight: 800;
            color: #ad2b00;
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .brand-header-exit {
            color: #2d3748;
            font-weight: 700;
            text-decoration: none;
            font-size: 0.95rem;
            display: flex;
            align-items: center;
            gap: 5px;
            transition: color 0.2s ease;
        }
        .brand-header-exit:hover {
            color: #ad2b00;
        }
        .progress-pawsitive-sm {
            height: 8px;
            background-color: #e2e8f0;
            border-radius: 9999px;
            overflow: hidden;
            border: 1px solid #cbd5e0;
        }
        .progress-bar-pawsitive-sm {
            background-color: #c05621;
            height: 100%;
            transition: width 0.3s ease;
        }
        .card-center-wizard {
            width: 100%;
            max-width: 600px;
            margin: 0 auto;
        }
        .deco-paw-left {
            position: absolute;
            top: 20px;
            left: 20px;
            font-size: 4rem;
            color: #cbd5e1;
            opacity: 0.4;
            pointer-events: none;
        }
        .deco-heart-right {
            position: absolute;
            bottom: 20px;
            right: 20px;
            font-size: 4rem;
            color: #cbd5e1;
            opacity: 0.4;
            pointer-events: none;
        }
        /* Mobile responsive adjustments */
        @@media (max-width: 768px) {
            .auth-card-left {
                display: none;
            }
            .auth-card {
                min-height: auto;
            }
            .auth-card-right {
                padding: 2rem 1.5rem;
            }
        }
    </style>
</head>
<body>
    <!-- Inline Diagnostics Console -->
    <div id="js-error-reporter" class="alert alert-danger m-3" style="position: fixed; z-index: 999999; top: 0; left: 0; right: 0; display: none;">
        <strong>JavaScript Error detected:</strong> <span id="js-error-msg"></span>
    </div>
    <script>
        window.addEventListener('error', function(e) {
            console.error("Caught error:", e);
            var reporter = document.getElementById('js-error-reporter');
            var msg = document.getElementById('js-error-msg');
            if (reporter && msg) {
                reporter.style.display = 'block';
                msg.textContent = e.message + " in " + e.filename + " line " + e.lineno;
            }
        });
    </script>

    <div class="auth-wrapper">
        <div class="auth-container">
            <!-- SECTION 1: SIGN IN AND SIGN UP STEP 1 (SPLIT CARD) -->
            <div id="auth-split-section" class="w-100 d-flex flex-column align-items-center">
                <div class="auth-card">
                    <!-- Left Side Column -->
                    <div id="auth-left-panel" class="auth-card-left text-center">
                        <!-- Sign In Left Content -->
                        <div id="brand-signin-content" class="w-100 h-100 d-flex flex-column justify-content-between">
                            <div>
                                <a class="pawsitive-logo fs-1 justify-content-center mb-3" asp-controller="Home" asp-action="Index">
                                    🐾 Pawsitive
                                </a>
                                <p class="lead mb-4 text-dark font-bold fs-5">
                                    Nơi những người bạn bốn chân tìm thấy mái ấm yêu thương.
                                </p>
                            </div>
                            <div class="p-3 bg-white border border-2 border-dark rounded-md shadow-flat my-3">
                                <div class="pet-frame ratio ratio-1x1 border border-1 border-dark overflow-hidden">
                                    <img src="https://images.unsplash.com/photo-1543466835-00a7907e9de1?auto=format&fit=crop&q=80&w=400" alt="Cute puppy" />
                                </div>
                            </div>
                            <div>
                                <span class="small font-bold text-dark d-block mb-1">Hành trình tìm nhà: 85% hoàn tất!</span>
                                <div class="progress-pawsitive" style="height: 12px">
                                    <div class="progress-bar-pawsitive" style="width: 85%">
                                        <div class="progress-bar-paw-icon" style="width: 22px; height: 22px; top: -5px; right: -5px; font-size: 0.6rem;">🐾</div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Sign Up Left Content -->
                        <div id="brand-signup-content" class="w-100 h-100 d-none d-flex flex-column justify-content-between align-items-center">
                            <!-- Background decorative symbols -->
                            <div class="deco-paw-left">🐾</div>
                            <div class="deco-heart-right">
                                <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
                                </svg>
                            </div>

                            <div style="z-index: 2; margin-top: auto; margin-bottom: auto;">
                                <div class="p-3 bg-white border border-2 border-dark mb-4 mx-auto" style="border-radius: 50%; width: 220px; height: 220px; overflow: hidden; box-shadow: 4px 4px 0px #2d3748;">
                                    <div class="w-100 h-100 overflow-hidden" style="border-radius: 50%;">
                                        <img src="https://images.unsplash.com/photo-1548199973-03cce0bbc87b?auto=format&fit=crop&q=80&w=400" alt="Dog and cat sitting" style="object-fit: cover; width: 100%; height: 100%;" />
                                    </div>
                                </div>
                                <h2 class="brand-font h3 mb-3 text-dark font-extrabold" style="font-weight: 800; font-size: 1.6rem;">
                                    Chào mừng bạn đến với Pawsitive Rescue!
                                </h2>
                                <p class="small text-muted font-semibold mb-0" style="line-height: 1.6; font-size: 0.95rem;">
                                    Hành trình tìm kiếm một người bạn bốn chân trung thành bắt đầu từ đây. Cảm ơn bạn đã sẵn lòng mở rộng vòng tay!
                                </p>
                            </div>
                        </div>
                    </div>

                    <!-- Right Side Column -->
                    <div class="auth-card-right">
                        <!-- CONTAINER 1: Sign In -->
                        <div id="signin-box-container">
                            <h2 class="brand-font h1 text-danger mb-2">Mừng bạn trở lại!</h2>
                            <p class="text-muted small mb-4">Hãy đăng nhập để tiếp tục hành trình cứu hộ.</p>

                            <form id="signin-form">
                                <div class="form-group-pawsitive mb-3">
                                    <label for="signin-identity">Email hoặc Số điện thoại</label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-white border-2 border-end-0 border-dark" style="border-radius: 10px 0 0 10px"><i class="bi bi-envelope"></i></span>
                                        <input type="text" class="form-control auth-input-custom border-start-0 w-auto flex-grow-1" id="signin-identity" placeholder="example@gmail.com" required style="border-top-left-radius: 0 !important; border-bottom-left-radius: 0 !important;" />
                                    </div>
                                </div>

                                <div class="form-group-pawsitive mb-3">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <label for="signin-password">Mật khẩu</label>
                                        <a asp-controller="Account" asp-action="ForgotPassword" class="small text-danger fw-bold text-decoration-none text-xs">Quên mật khẩu?</a>
                                    </div>
                                    <div class="input-group">
                                        <span class="input-group-text bg-white border-2 border-end-0 border-dark" style="border-radius: 10px 0 0 10px"><i class="bi bi-lock"></i></span>
                                        <input type="password" class="form-control auth-input-custom border-start-0 border-end-0 w-auto flex-grow-1" id="signin-password" placeholder="........" required style="border-radius: 0" />
                                        <span class="input-group-text bg-white border-2 border-start-0 border-dark password-eye-toggle cursor-pointer bi bi-eye" data-target="signin-password" style="border-radius: 0 10px 10px 0"></span>
                                    </div>
                                </div>

                                <div class="form-check mb-4">
                                    <input class="form-check-input" type="checkbox" id="check-remember" checked />
                                    <label class="form-check-label small cursor-pointer" for="check-remember">Ghi nhớ đăng nhập</label>
                                </div>

                                <div class="alert alert-danger rounded-md d-none small py-2" id="signin-error">
                                    <i class="bi bi-exclamation-circle-fill"></i>
                                    <span id="signin-error-text"></span>
                                </div>

                                <button type="submit" class="btn btn-pawsitive btn-pawsitive-primary w-100 rounded-full justify-content-center py-2 fs-5 mb-4">
                                    Đăng nhập ➔
                                </button>

                                <div class="text-center small">
                                    Chưa có tài khoản?
                                    <a href="#" class="text-danger fw-bold text-decoration-none" id="link-to-signup">Đăng ký ngay</a>
                                </div>
                            </form>
                        </div>

                        <!-- CONTAINER 2: Sign Up Step 1 -->
                        <div id="signup-step1-container" class="d-none">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span class="small text-danger font-bold" style="font-weight: 700; color: #c05621;">Bước 1/3: Tạo tài khoản</span>
                                <span class="small text-muted italic">Gần xong rồi!!</span>
                            </div>
                            <div class="progress-pawsitive-sm mb-4">
                                <div class="progress-bar-pawsitive-sm" style="width: 33%;"></div>
                            </div>

                            <h2 class="brand-font h3 text-dark mb-1 font-bold" style="font-weight: 800;">Thông tin cơ bản</h2>
                            <p class="text-muted small mb-4">Vui lòng nhập đầy đủ thông tin để tham gia cộng đồng cứu hộ.</p>

                            <form id="signup-step1-form">
                                <div class="form-group-pawsitive mb-3">
                                    <label for="signup-fullname" class="font-semibold text-xs text-muted mb-1 d-block">Họ và tên</label>
                                    <input type="text" class="form-control auth-input-custom" id="signup-fullname" placeholder="Nguyễn Văn A" required />
                                </div>
                                
                                <div class="form-group-pawsitive mb-3">
                                    <label for="signup-email" class="font-semibold text-xs text-muted mb-1 d-block">Email</label>
                                    <input type="email" class="form-control auth-input-custom" id="signup-email" placeholder="vi-du@email.com" required />
                                </div>

                                <div class="form-group-pawsitive mb-3">
                                    <label for="signup-phone" class="font-semibold text-xs text-muted mb-1 d-block">Số điện thoại</label>
                                    <input type="text" class="form-control auth-input-custom" id="signup-phone" placeholder="090 123 4567" required />
                                </div>

                                <div class="form-group-pawsitive mb-3">
                                    <label for="signup-password" class="font-semibold text-xs text-muted mb-1 d-block">Mật khẩu</label>
                                    <div class="input-group">
                                        <input type="password" class="form-control auth-input-custom border-end-0 w-auto flex-grow-1" id="signup-password" placeholder="••••••••" required style="border-top-right-radius: 0 !important; border-bottom-right-radius: 0 !important;" />
                                        <span class="input-group-text bg-white border-2 border-start-0 border-dark password-eye-toggle cursor-pointer bi bi-eye" data-target="signup-password" style="border-top-right-radius: 10px; border-bottom-right-radius: 10px; border-color: #2d3748 !important; background-color: #fefdf9 !important;"></span>
                                    </div>
                                </div>

                                <div class="form-group-pawsitive mb-4">
                                    <label for="signup-confirm-password" class="font-semibold text-xs text-muted mb-1 d-block">Xác nhận mật khẩu</label>
                                    <input type="password" class="form-control auth-input-custom" id="signup-confirm-password" placeholder="••••••••" required />
                                </div>

                                <div class="d-flex justify-content-between align-items-center mt-4">
                                    <div class="small">
                                        Bạn đã có tài khoản?<br/>
                                        <a href="#" class="text-danger fw-bold text-decoration-none" id="link-to-signin">Đăng nhập</a>
                                    </div>
                                    <button type="submit" class="btn btn-pawsitive btn-pawsitive-primary rounded-xl px-4 py-2 text-white font-bold" style="background-color: #c05621; border: 2px solid #000; box-shadow: 2px 2px 0px #000;">
                                        Tiếp theo <i class="bi bi-arrow-right"></i>
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>

                <!-- Footer under card (detailed) -->
                <div class="w-100 max-container mt-5 pt-3">
                    <footer class="py-5 text-dark" style="background-color: #e8e6db; border-top: 2px solid #2d3748; border-radius: 20px; padding: 2rem !important; box-shadow: 4px 4px 0px #2d3748; border: 2px solid #2d3748;">
                        <div class="container-fluid">
                            <div class="row g-4 text-start">
                                <div class="col-md-5">
                                    <h5 class="brand-font font-bold mb-3" style="color: #ad2b00; font-size: 1.5rem;">🐾 Pawsitive Rescue</h5>
                                    <p class="small text-muted" style="line-height: 1.6; max-width: 320px;">
                                        Kết nối những trái tim yêu động vật.
                                    </p>
                                </div>
                                <div class="col-md-3">
                                    <h5 class="brand-font font-bold mb-3" style="font-size: 1.1rem;">Về chúng tôi</h5>
                                    <ul class="list-unstyled small d-flex flex-column gap-2">
                                        <li><a href="/" class="text-dark text-decoration-none">Sitemap</a></li>
                                        <li><a href="#" class="text-dark text-decoration-none">Privacy Policy</a></li>
                                    </ul>
                                </div>
                                <div class="col-md-4">
                                    <h5 class="brand-font font-bold mb-3" style="font-size: 1.1rem;">Liên hệ</h5>
                                    <ul class="list-unstyled small d-flex flex-column gap-2">
                                        <li><a href="#" class="text-dark text-decoration-none">Contact Us</a></li>
                                        <li><a href="#" class="text-dark text-decoration-none">Social Media</a></li>
                                    </ul>
                                </div>
                            </div>
                            <hr class="my-4" style="border-color: rgba(0,0,0,0.15);" />
                            <div class="text-center small text-muted">
                                &copy; 2024 Pawsitive Rescue. All rights reserved.
                            </div>
                        </div>
                    </footer>
                </div>
            </div>

            <!-- SECTION 2: SIGN UP STEP 2 (OTP VERIFICATION CENTERED CARD) -->
            <div id="auth-otp-section" class="w-100 d-none flex-column align-items-center">
                <!-- Simple header -->
                <div class="brand-header">
                    <a class="brand-header-logo" href="/">🐾 Pawsitive Rescue</a>
                    <a class="brand-header-exit" href="#" id="otp-exit-btn"><i class="bi bi-x-lg"></i> Thoát</a>
                </div>

                <div class="card-center-wizard text-start">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="small text-danger font-bold" style="font-weight: 700; color: #c05621;">Bước 2: Xác thực OTP</span>
                        <span class="small text-muted italic">2/3 bước hoàn tất</span>
                    </div>
                    <div class="progress-pawsitive-sm mb-4">
                        <div class="progress-bar-pawsitive-sm" style="width: 66%;"></div>
                    </div>

                    <div class="card border-2 border-dark p-4 bg-white mb-4 text-center" style="border-radius: 24px; box-shadow: 4px 4px 0px #000;">
                        <div class="pet-frame ratio ratio-1x1 border border-1 border-dark overflow-hidden mb-3 mx-auto" style="border-radius: 50%; width: 140px; height: 140px; box-shadow: 3px 3px 0px #2d3748;">
                            <img src="https://images.unsplash.com/photo-1583511655857-d19b40a7a54e?auto=format&fit=crop&q=80&w=200" alt="OTP Dog" />
                        </div>
                        
                        <h3 class="brand-font h4 text-dark font-extrabold mb-2" style="font-weight: 800;">Kiểm tra tin nhắn nhé!</h3>
                        <p class="text-muted small mb-4" style="font-size: 0.85rem; line-height: 1.5;">
                            Mã xác thực gồm 6 chữ số đã được gửi đến<br/>
                            <strong class="text-dark" id="otp-sent-email">user***@@gmail.com</strong>
                        </p>

                        <!-- 6 Rounded inputs for OTP -->
                        <div class="d-flex justify-content-between gap-2 mb-4" style="max-width: 320px; margin: 0 auto;" id="otp-inputs-row">
                            <input type="text" class="form-control otp-input-box" maxlength="1" pattern="[0-9]" inputmode="numeric" />
                            <input type="text" class="form-control otp-input-box" maxlength="1" pattern="[0-9]" inputmode="numeric" />
                            <input type="text" class="form-control otp-input-box" maxlength="1" pattern="[0-9]" inputmode="numeric" />
                            <input type="text" class="form-control otp-input-box" maxlength="1" pattern="[0-9]" inputmode="numeric" />
                            <input type="text" class="form-control otp-input-box" maxlength="1" pattern="[0-9]" inputmode="numeric" />
                            <input type="text" class="form-control otp-input-box" maxlength="1" pattern="[0-9]" inputmode="numeric" />
                        </div>

                        <div class="small text-muted mb-4 font-semibold">
                            Bạn chưa nhận được mã?<br/>
                            <a href="#" class="text-danger fw-bold text-decoration-none disabled" id="otp-resend-link" style="pointer-events: none; opacity: 0.6;">Gửi lại mã (<span id="otp-timer-count">58s</span>)</a>
                        </div>

                        <button type="button" class="btn btn-pawsitive btn-pawsitive-primary w-100 rounded-xl py-2 px-4 text-white font-bold" id="signup-next-2" style="background-color: #c05621; border: 2px solid #000; box-shadow: 2px 2px 0px #000;">
                            Tiếp tục <i class="bi bi-arrow-right"></i>
                        </button>
                    </div>

                    <div class="text-center small text-muted font-semibold mt-3">
                        Gặp khó khăn khi xác thực? <a href="#" class="text-danger text-decoration-none" onclick="showToast('📞 Vui lòng gọi Hotline cứu hộ!', 'info'); return false;">Liên hệ bộ phận cứu hộ</a> của chúng tôi ngay.
                    </div>
                </div>

                <!-- Page footer simple -->
                <div class="w-100 mt-5 pt-4 text-center small text-muted">
                    &copy; 2024 Pawsitive Rescue. All rights reserved.
                </div>
            </div>

            <!-- SECTION 3: SIGN UP STEP 3 (PROFILE COMPLETION CENTERED CARD) -->
            <div id="auth-profile-section" class="w-100 d-none flex-column align-items-center">
                <div class="card-center-wizard text-start">
